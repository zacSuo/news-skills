# 科技热点周报邮件配置（复制为 .env 并填写，勿提交 .env）
# 收件人（可多个，逗号分隔）
REPORT_EMAIL_TO=your-email@example.com

# 网页企业邮箱 / 企业邮箱 SMTP（常用 465 或 587）
# 465 一般为 SSL，587 一般为 STARTTLS；以企业邮箱后台说明为准
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-account@example.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM=科技周报 <your-account@example.com>

# 百度翻译 API（报告标题与摘要英→中，不配置则保留英文）
# 必须用「通用翻译」应用的 APP ID + 密钥；且须在控制台为该应用「开通通用翻译」服务（立即开通）
# 若 52003 仍出现，可尝试旧版接口：BAIDU_TRANSLATE_HOST=api.fanyi.baidu.com
# 测试：npm run report:test-translate
BAIDU_TRANSLATE_APPID=
BAIDU_TRANSLATE_KEY=
# BAIDU_TRANSLATE_HOST=api.fanyi.baidu.com

# 测试发信：npm run report:test-email
